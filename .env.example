# Copy this file to `.env` and fill in real values.
# Never commit `.env` to source control.

# identitype Partner API
# In production this MUST be HTTPS.
IDENTITYPE_BASE_URL=https://api.identitype.example.com/api/partner
IDENTITYPE_API_KEY=<your-identitype-api-key>
IDENTITYPE_TIMEOUT_SECONDS=30

# Flask
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=replace_me_with_a_long_random_string
FLASK_DEBUG=0
PORT=5000

# Logging
LOG_LEVEL=INFO
