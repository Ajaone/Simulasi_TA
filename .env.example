# Copy this file to `.env` and fill in real values.
# Never commit `.env` to source control.

# SecAuth Partner API
# In production this MUST be HTTPS.
SECAUTH_BASE_URL=https://api.secauth.example.com/api/partner
SECAUTH_API_KEY=<your-secauth-api-key>
SECAUTH_TIMEOUT_SECONDS=30

# Flask
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=replace_me_with_a_long_random_string
FLASK_DEBUG=0
PORT=5000

# Logging
LOG_LEVEL=INFO
