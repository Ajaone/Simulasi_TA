      "name": "Enrollment",
      "description": "Folder untuk semua request enrollment pola ketikan pengguna.",
      "item": [
        {
          "name": "Enroll — Success (sample data)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Response has success=true', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Response contains templates_count', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('templates_count');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"events\": [\n    { \"evt\": \"d\", \"key\": \"p\", \"code\": \"KeyP\", \"t\": 0.0 },\n    { \"evt\": \"u\", \"key\": \"p\", \"code\": \"KeyP\", \"t\": 82.5 },\n    { \"evt\": \"d\", \"key\": \"a\", \"code\": \"KeyA\", \"t\": 210.3 },\n    { \"evt\": \"u\", \"key\": \"a\", \"code\": \"KeyA\", \"t\": 295.1 },\n    { \"evt\": \"d\", \"key\": \"s\", \"code\": \"KeyS\", \"t\": 380.0 },\n    { \"evt\": \"u\", \"key\": \"s\", \"code\": \"KeyS\", \"t\": 461.2 },\n    { \"evt\": \"d\", \"key\": \"s\", \"code\": \"KeyS\", \"t\": 520.5 },\n    { \"evt\": \"u\", \"key\": \"s\", \"code\": \"KeyS\", \"t\": 601.3 },\n    { \"evt\": \"d\", \"key\": \"w\", \"code\": \"KeyW\", \"t\": 700.0 },\n    { \"evt\": \"u\", \"key\": \"w\", \"code\": \"KeyW\", \"t\": 780.5 },\n    { \"evt\": \"d\", \"key\": \"o\", \"code\": \"KeyO\", \"t\": 850.2 },\n    { \"evt\": \"u\", \"key\": \"o\", \"code\": \"KeyO\", \"t\": 930.8 },\n    { \"evt\": \"d\", \"key\": \"r\", \"code\": \"KeyR\", \"t\": 1010.0 },\n    { \"evt\": \"u\", \"key\": \"r\", \"code\": \"KeyR\", \"t\": 1097.4 },\n    { \"evt\": \"d\", \"key\": \"d\", \"code\": \"KeyD\", \"t\": 1180.0 },\n    { \"evt\": \"u\", \"key\": \"d\", \"code\": \"KeyD\", \"t\": 1260.6 }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/enroll",
              "host": ["{{base_url}}"],
              "path": ["enroll"]
            },
            "description": "Mendaftarkan pola ketikan pengguna ke identitype.\n\nPanggil endpoint ini minimal 3 kali dengan data events yang direkam secara nyata dari pengguna untuk membangun template biometrik yang stabil.\n\n**Fields:**\n- `username` : Identifier unik pengguna (UUID direkomendasikan)\n- `events`   : Array event keystroke (keydown/keyup) yang direkam"
          },
