    {
      "key": "base_url",
      "value": "https://identitype.duckdns.org/api/partner",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "<YOUR_API_KEY>",
      "type": "string"
    },
    {
      "key": "username",
      "value": "test-user-550e8400-e29b-41d4",
      "type": "string"
    }
